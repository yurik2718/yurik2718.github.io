---
// Custom cursor · Cursor spotlight · Scroll reveal
---

<div class="c-dot" id="c-dot" aria-hidden="true"></div>
<div class="c-ring" id="c-ring" aria-hidden="true"></div>

<script>
  import { gsap } from 'gsap'

  const IS_POINTER = window.matchMedia('(hover: hover) and (pointer: fine)').matches

  /* ═══════════════════════════════════════
     CURSOR
  ═══════════════════════════════════════ */
  function initCursor() {
    const dot  = document.getElementById('c-dot')
    const ring = document.getElementById('c-ring')
    if (!dot || !ring) return

    // Centre both via GSAP (avoids CSS transform conflict)
    gsap.set([dot, ring], { xPercent: -50, yPercent: -50, x: -300, y: -300 })

    if (!IS_POINTER) {
      dot.style.display  = 'none'
      ring.style.display = 'none'
      return
    }

    let mx = -300, my = -300
    let rx = -300, ry = -300

    window.addEventListener('mousemove', (e) => {
      mx = e.clientX
      my = e.clientY

      // Dot follows instantly
      gsap.set(dot, { x: mx, y: my })

      // Spotlight CSS vars
      document.documentElement.style.setProperty('--cx', `${mx}px`)
      document.documentElement.style.setProperty('--cy', `${my}px`)
      document.documentElement.classList.add('cursor-ready')
    })

    // Ring follows with lerp
    gsap.ticker.add(() => {
      rx += (mx - rx) * 0.1
      ry += (my - ry) * 0.1
      gsap.set(ring, { x: rx, y: ry })
    })

    // Fade on window leave / enter
    window.addEventListener('mouseleave', () =>
      gsap.to([dot, ring], { opacity: 0, duration: 0.4 }),
    )
    window.addEventListener('mouseenter', () =>
      gsap.to([dot, ring], { opacity: 1, duration: 0.4 }),
    )
  }

  /* Hover states — needs rebinding after view-transition */
  function bindHover() {
    const dot  = document.getElementById('c-dot')
    const ring = document.getElementById('c-ring')
    if (!dot || !ring || !IS_POINTER) return

    document.querySelectorAll('a, button').forEach((el) => {
      el.addEventListener('mouseenter', () => {
        dot.classList.add('c-dot--h')
        ring.classList.add('c-ring--h')
      })
      el.addEventListener('mouseleave', () => {
        dot.classList.remove('c-dot--h')
        ring.classList.remove('c-ring--h')
      })
    })
  }

  /* ═══════════════════════════════════════
     SCROLL REVEAL
  ═══════════════════════════════════════ */
  function initReveal() {
    // Respect reduced-motion: leave everything in its natural, visible state
    // (the hiding below is what the animations reveal from).
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    /* ── Section headings: slide up from overflow mask ── */
    document.querySelectorAll<HTMLElement>('.section-heading').forEach((el) => {
      // Skip if already wrapped from a previous init
      if ((el.parentElement as HTMLElement)?.dataset?.revealWrap !== undefined) return
      const wrap = document.createElement('div')
      wrap.dataset.revealWrap = ''
      wrap.style.cssText = 'overflow:hidden; display:block'
      el.parentElement!.insertBefore(wrap, el)
      wrap.appendChild(el)
      gsap.set(el, { yPercent: 115 })
    })

    /* ── Fade-up elements ── */
    gsap.set(
      '.about-text, .contact-text, .about-tags, .build-hero, .builds-grid, .upcoming-list, .contact-links',
      { y: 30, opacity: 0 },
    )

    /* ── Skill columns (stagger) ── */
    const cols = document.querySelectorAll<HTMLElement>('.skill-col')
    gsap.set(cols, { y: 40, opacity: 0 })

    /* ── Observer ── */
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(({ target, isIntersecting }) => {
          if (!isIntersecting) return
          const el = target as HTMLElement

          if (el.classList.contains('section-heading')) {
            gsap.to(el, {
              yPercent: 0,
              duration: 1.1,
              ease: 'power4.out',
            })
          } else if (el.classList.contains('skill-col')) {
            const idx = Array.from(cols).indexOf(el)
            gsap.to(el, {
              y: 0, opacity: 1,
              duration: 0.8,
              ease: 'power3.out',
              delay: idx * 0.13,
            })
          } else {
            gsap.to(el, {
              y: 0, opacity: 1,
              duration: 0.75,
              ease: 'power3.out',
            })
          }

          observer.unobserve(el)
        })
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
    )

    document
      .querySelectorAll(
        '.section-heading, .about-text, .contact-text, .about-tags, .skill-col, .build-hero, .builds-grid, .upcoming-list, .contact-links',
      )
      .forEach((el) => observer.observe(el))
  }

  /* ═══════════════════════════════════════
     BOOTSTRAP
  ═══════════════════════════════════════ */
  initCursor()
  bindHover()
  initReveal()

  document.addEventListener('astro:after-swap', () => {
    bindHover()
    initReveal()
  })
</script>

<style is:global>
  /* ── Hide native cursor on real pointer devices ── */
  @media (hover: hover) and (pointer: fine) {
    *, *::before, *::after { cursor: none !important; }
  }

  /* ── Dot ── */
  .c-dot {
    position: fixed;
    inset: 0 auto auto 0;
    width: 5px;
    height: 5px;
    background: #eeebe6;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
    transition: width 0.18s ease, height 0.18s ease;
  }

  .c-dot--h {
    width: 8px;
    height: 8px;
  }

  /* ── Ring ── */
  .c-ring {
    position: fixed;
    inset: 0 auto auto 0;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(238, 235, 230, 0.22);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    will-change: transform;
    transition:
      width  0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      height 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 0.3s ease;
  }

  .c-ring--h {
    width: 54px;
    height: 54px;
    border-color: rgba(238, 235, 230, 0.48);
  }

  /* ── Spotlight (mouse follow glow) ── */
  :root {
    --cx: 50vw;
    --cy: 50vh;
  }

  html::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(
      700px circle at var(--cx) var(--cy),
      rgba(255, 255, 255, 0.03),
      transparent 50%
    );
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transition: opacity 2s ease;
  }

  html.cursor-ready::before {
    opacity: 1;
  }
</style>
