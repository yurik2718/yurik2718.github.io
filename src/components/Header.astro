---
import Icon from './Icon.astro'
import { navLinks } from '../data/navigation'
import { profile } from '../data/profile'

const currentPath = Astro.url.pathname
const [logoFirst, logoLast] = profile.name.toUpperCase().split(' ')

const socialLinks = [
  profile.social.github   && { href: profile.social.github,   label: 'GitHub',   icon: 'github'   },
  profile.social.telegram && { href: profile.social.telegram, label: 'Telegram', icon: 'telegram' },
].filter(Boolean) as { href: string; label: string; icon: string }[]

const year = new Date().getFullYear()
---

{/* ── Fixed header ── */}
<header id="main-header" class="site-header">
  <nav
    class="mx-auto flex max-w-[var(--container-grid)] items-center justify-between px-5 py-3 md:py-4"
    aria-label="Main navigation"
  >
    <a href="/" class="logo-link">
      <span class="logo-first">{logoFirst}</span>
      <span class="logo-sep"> · </span>
      <span class="logo-last">{logoLast}</span>
    </a>

    {/* Desktop nav */}
    <ul class="hidden md:flex items-center gap-7">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', currentPath.startsWith(href) ? 'nav-link--active' : '']}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    {/* Mobile toggle */}
    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-11 h-11 -mr-2 text-white/50 hover:text-white transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="toggle-icon-menu"><Icon name="menu" size={22} /></span>
      <span class="toggle-icon-close"><Icon name="x" size={22} /></span>
    </button>
  </nav>

  <div class="header-accent" />
</header>

{/* ── Full-screen mobile menu ── */}
<div id="mobile-menu" class="mobile-menu" aria-hidden="true">

  {/* Top bar — mirrors header */}
  <div class="menu-topbar">
    <nav
      class="mx-auto flex max-w-[var(--container-grid)] items-center justify-between w-full"
      aria-label="Menu close"
    >
      <a href="/" class="logo-link">
        <span class="logo-first">{logoFirst}</span>
        <span class="logo-sep"> · </span>
        <span class="logo-last">{logoLast}</span>
      </a>
      <button
        id="menu-close"
        class="flex items-center justify-center w-11 h-11 -mr-2 text-white/50 hover:text-white transition-colors"
        aria-label="Close menu"
      >
        <Icon name="x" size={22} />
      </button>
    </nav>
  </div>

  {/* Nav links */}
  <div class="menu-content">
    {navLinks.length > 0 && (
      <>
        <p class="menu-kicker">Navigate</p>
        <nav>
          <ul>
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class:list={[
                    'menu-link',
                    currentPath.startsWith(href) ? 'menu-link--active' : '',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </>
    )}
  </div>

  {/* Bottom — social + copyright */}
  <div class="menu-footer">
    <div class="menu-rule" />
    <div class="menu-footer-inner">
      <div class="flex items-center gap-5">
        {socialLinks.map(({ href, label, icon }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="menu-social-link"
          >
            <Icon name={icon} size={13} />
            <span>{label}</span>
          </a>
        ))}
      </div>
      <p class="menu-copy">&copy; {profile.name} {year}</p>
    </div>
  </div>

</div>

{/* Spacer */}
<div class="h-[52px] md:h-[62px]" />

<script>
  let scrollAbort = new AbortController()

  function initHeader() {
    const header = document.getElementById('main-header')
    const menu   = document.getElementById('mobile-menu')
    const toggle = document.getElementById('menu-toggle')
    const close  = document.getElementById('menu-close')

    if (!header || !menu || !toggle || !close) return

    // ── Reset DOM state on every init (critical for View Transitions) ──
    menu.classList.remove('is-open')
    menu.setAttribute('aria-hidden', 'true')
    toggle.classList.remove('is-open')
    toggle.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''

    let isOpen  = false
    let lastY   = window.scrollY
    let ticking = false

    // ── Auto-hide on scroll ──
    scrollAbort.abort()
    scrollAbort = new AbortController()

    function onScroll() {
      if (ticking) return
      ticking = true
      requestAnimationFrame(() => {
        const y = window.scrollY
        if (!isOpen) {
          if (y <= 10)            header.classList.remove('header--hidden')
          else if (y > lastY + 8) header.classList.add('header--hidden')
          else if (y < lastY - 4) header.classList.remove('header--hidden')
        }
        lastY   = y
        ticking = false
      })
    }

    window.addEventListener('scroll', onScroll, {
      passive: true,
      signal: scrollAbort.signal,
    })

    const links = Array.from(menu.querySelectorAll<HTMLElement>('.menu-link'))

    function openMenu() {
      if (isOpen) return
      isOpen = true
      // Don't force-show header — menu has its own topbar; forcing it causes logo jitter
      toggle.setAttribute('aria-expanded', 'true')
      toggle.classList.add('is-open')
      menu.classList.add('is-open')
      menu.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }

    function closeMenu() {
      if (!isOpen) return
      isOpen = false
      toggle.setAttribute('aria-expanded', 'false')
      toggle.classList.remove('is-open')
      menu.classList.remove('is-open')
      menu.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
    }

    toggle.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()))
    close.addEventListener('click', closeMenu)
    links.forEach((l) => l.addEventListener('click', closeMenu))
  }

  initHeader()
  document.addEventListener('astro:after-swap', initHeader)
</script>

<style>
  /* ── Header ── */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: rgba(17, 17, 17, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transform: translateY(0);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-header.header--hidden {
    transform: translateY(-100%);
  }

  .header-accent {
    position: absolute;
    bottom: -2px; left: 0; right: 0;
    height: 2px;
    background: var(--color-terra);
  }

  /* ── Toggle icon swap ── */
  .toggle-icon-close              { display: none; }
  .toggle-icon-menu               { display: flex; }
  #menu-toggle.is-open .toggle-icon-menu  { display: none; }
  #menu-toggle.is-open .toggle-icon-close { display: flex; }

  /* ── Logo ── */
  .logo-link {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-decoration: none;
    display: flex;
    align-items: baseline;
    transition: opacity 0.2s;
  }

  .logo-link:hover { opacity: 0.75; }

  .logo-first {
    font-weight: 300;
    color: rgba(242, 235, 224, 0.55);
    letter-spacing: 0.03em;
  }

  .logo-sep {
    font-weight: 300;
    color: var(--color-terra);
    opacity: 0.6;
    font-size: 0.9em;
  }

  .logo-last {
    font-weight: 800;
    color: #f2ebe0;
    letter-spacing: -0.01em;
  }

  /* ── Desktop nav ── */
  .nav-link {
    position: relative;
    color: rgba(242, 235, 224, 0.55);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    padding-bottom: 3px;
    transition: color 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover           { color: white; }
  .nav-link:hover::after    { transform: scaleX(1); }
  .nav-link--active         { color: var(--color-accent); }
  .nav-link--active::after  { transform: scaleX(1); }

  /* ────────────────────────────────────
     Full-screen mobile menu
  ──────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: #111111;
    display: flex;
    flex-direction: column;
    /* Closed: invisible, no movement */
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Top bar */
  .menu-topbar {
    padding: 0 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    flex-shrink: 0;
  }

  .menu-topbar nav {
    padding: 0.75rem 0;
  }

  /* Nav content — vertically centered */
  .menu-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 1.25rem;
  }

  .menu-kicker {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(242, 235, 224, 0.22);
    margin-bottom: 1.75rem;
  }

  /* Nav links */
  .menu-link {
    display: block;
    position: relative;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 8vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: rgba(242, 235, 224, 0.28);
    text-decoration: none;
    padding: 0.45rem 0 0.45rem 1.5rem;
    transition: color 0.3s ease;
    /* Closed: invisible */
    opacity: 0;
  }

  .mobile-menu.is-open .menu-link {
    opacity: 1;
  }

  .menu-link:hover {
    color: rgba(242, 235, 224, 0.82);
  }

  /* Terra left bar indicator */
  .menu-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 2.5px;
    height: 48%;
    background: var(--color-terra);
    border-radius: 2px;
    transform: translateY(-50%) scaleY(0);
    transition: transform 0.22s ease;
  }

  .menu-link--active {
    color: rgba(242, 235, 224, 0.95);
  }

  .menu-link--active::before {
    transform: translateY(-50%) scaleY(1);
  }

  /* Bottom */
  .menu-footer {
    flex-shrink: 0;
    padding: 0 1.25rem max(1.5rem, env(safe-area-inset-bottom));
  }

  .menu-rule {
    height: 1px;
    background: rgba(242, 235, 224, 0.07);
    margin-bottom: 1.25rem;
  }

  .menu-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .menu-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(242, 235, 224, 0.35);
    text-decoration: none;
    transition: color 0.2s;
  }

  .menu-social-link:hover {
    color: rgba(242, 235, 224, 0.8);
  }

  .menu-copy {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: rgba(242, 235, 224, 0.18);
  }
</style>
