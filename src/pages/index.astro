---
import Base from '../layouts/Base.astro'
import BuildCard from '../components/BuildCard.astro'
import Icon from '../components/Icon.astro'
import { profile } from '../data/profile'
import { builds, kindLabel } from '../data/builds'
import { skillSections } from '../data/skills'
import { background } from '../data/background'

const sorted = [...builds].sort((a, b) => a.position - b.position)
const heroProject = sorted.find(b => b.status === 'active')
const activeProjects = sorted.filter(b => b.status === 'active' && b !== heroProject)
const upcoming = sorted.filter(b => b.status === 'soon')
const pastProjects = sorted.filter(b => b.status === 'completed' || b.status === 'archived')
const professionalWork = pastProjects.filter(b => b.kind === 'business')
const otherPast = pastProjects.filter(b => b.kind !== 'business')

const heroSince = heroProject?.startedOn
  ? new Date(heroProject.startedOn).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
  : null
---

<Base title={`${profile.name} — Ruby on Rails Engineer`} description={profile.bio}>

  {/* ── Hero ── */}
  <section class="hero" id="hero">
    <canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

    <div class="hero-inner" id="hero-inner">
      <div class="hero-avatar" id="hero-avatar">
        <img src={profile.avatar} alt={profile.name} class="hero-avatar-img" />
      </div>

      <p class="hero-available" id="hero-available">
        <span class="avail-dot"></span>
        Open to work
      </p>

      <h1 class="hero-name" id="hero-name">{profile.name}</h1>

      <div class="hero-rule" id="hero-rule"></div>

      <div class="hero-roles" id="hero-roles">
        <span class="hero-role">Ruby on Rails</span>
        <span class="hero-sep">·</span>
        <span class="hero-role">Industrial Automation</span>
        <span class="hero-sep">·</span>
        <span class="hero-role hero-role--dim">Rust</span>
      </div>

      <div class="hero-actions" id="hero-actions">
        {profile.social.telegram && (
          <a href={profile.social.telegram} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn--primary">
            <Icon name="telegram" size={13} />
            Telegram
          </a>
        )}
        {profile.social.github && (
          <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="hero-btn">
            <Icon name="github" size={13} />
            GitHub
          </a>
        )}
      </div>
    </div>

    <div class="scroll-cue" id="scroll-cue">
      <span class="scroll-cue-label">scroll</span>
      <div class="scroll-cue-line"></div>
    </div>
  </section>

  {/* ── About ── */}
  <section class="page-section" id="about">
    <div class="section-wrap">
      <div class="section-num" aria-hidden="true">01</div>
      <div class="about-body">
        <h2 class="section-heading">
          Backend engineer.<br />Automation<br />background.
        </h2>
        <p class="about-text">
          Before writing software I spent years building control systems for
          industrial machines — PLCs, SCADA, Modbus, OPC UA. Production
          environments where downtime has a real cost — that shapes how you write software.
        </p>
        <p class="about-text">
          Now I build backends with Ruby on Rails. I'm learning Rust for the
          same reason I once chose CODESYS: because correctness matters.
        </p>

        <div class="about-tags">
          <div class="about-tag">
            <span class="about-tag-key">Primary stack</span>
            <span class="about-tag-val">Ruby on Rails</span>
          </div>
          <div class="about-tag">
            <span class="about-tag-key">Previous domain</span>
            <span class="about-tag-val">Industrial Automation</span>
          </div>
          <div class="about-tag">
            <span class="about-tag-key">Exploring</span>
            <span class="about-tag-val">Rust</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Skills ── */}
  <section class="page-section" id="skills">
    <div class="section-wrap">
      <div class="section-num" aria-hidden="true">02</div>
      <div class="skills-body">
        <h2 class="section-heading">Skills</h2>
        <div class="skills-grid">
          {skillSections.map((sec) => (
            <div class="skill-col">
              <h3 class="skill-col-title">{sec.title}</h3>
              {sec.categories.map((cat) => (
                <div class="skill-group">
                  <span class="skill-label">{cat.label}</span>
                  <div class="skill-tags">
                    {cat.skills.map((skill) => (
                      <span class={`skill-tag${cat.label === 'Exploring' ? ' skill-tag--exploring' : ''}`}>
                        {skill}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── Background ── */}
  {background.length > 0 && (
    <section class="page-section" id="background">
      <div class="section-wrap">
        <div class="section-num" aria-hidden="true">03</div>
        <div class="background-body">
          <h2 class="section-heading">Background</h2>
          <div class="bg-groups">
            {background.map((group) => (
              <div class="bg-group">
                <p class="bg-group-label">{group.label}</p>
                <div class="bg-timeline">
                  {group.entries.map((entry) => (
                    <div class="bg-entry">
                      <span class="bg-year">{entry.year}</span>
                      <div class="bg-entry-body">
                        {entry.url ? (
                          <a href={entry.url} target="_blank" rel="noopener noreferrer" class="bg-title bg-title--link">
                            {entry.title}
                            <Icon name="arrow-up-right" size={12} />
                          </a>
                        ) : (
                          <span class="bg-title">{entry.title}</span>
                        )}
                        <span class="bg-role">{entry.role}</span>
                        {entry.detail && <span class="bg-detail">{entry.detail}</span>}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ── Builds ── */}
  {(heroProject || activeProjects.length > 0 || upcoming.length > 0) && (
    <section class="page-section" id="builds">
      <div class="section-wrap">
        <div class="section-num" aria-hidden="true">04</div>
        <div class="builds-body">
          <h2 class="section-heading">Builds</h2>

          {heroProject && (
            <div class="build-hero">
              <div class="build-hero-meta">
                <span class="build-kind">{kindLabel[heroProject.kind]}</span>
                <span class="build-sep">·</span>
                <span class="build-status">{heroProject.status}</span>
                {heroSince && <span class="build-since">Since {heroSince}</span>}
              </div>
              <a href={heroProject.url} target="_blank" rel="noopener noreferrer" class="build-hero-link">
                <h3 class="build-hero-title">{heroProject.title}</h3>
                <span class="build-hero-arrow"><Icon name="arrow-up-right" size={26} /></span>
              </a>
              <p class="build-hero-desc">{heroProject.description}</p>
              {heroProject.stack && heroProject.stack.length > 0 && (
                <div class="build-hero-stack">
                  {heroProject.stack.map(tech => <span class="build-tech">{tech}</span>)}
                </div>
              )}
            </div>
          )}

          {activeProjects.length > 0 && (
            <div class="builds-grid">
              {activeProjects.map((build) => (
                <BuildCard build={build} />
              ))}
            </div>
          )}

          {upcoming.length > 0 && (
            <div class="upcoming-list">
              <p class="upcoming-label">On the horizon</p>
              {upcoming.map((build) => (
                <div class="upcoming-item">
                  <span class="upcoming-title">{build.title}</span>
                  <span class="upcoming-desc">{build.description}</span>
                </div>
              ))}
            </div>
          )}

          {professionalWork.length > 0 && (
            <div class="prowork-list">
              <p class="prowork-label">Professional work</p>
              {professionalWork.map((build) => (
                <a href={build.url} target="_blank" rel="noopener noreferrer" class="prowork-item">
                  <div class="prowork-head">
                    <h3 class="prowork-title">{build.title}</h3>
                    <span class="prowork-arrow"><Icon name="arrow-up-right" size={18} /></span>
                  </div>
                  <p class="prowork-desc">{build.description}</p>
                  {build.stack && build.stack.length > 0 && (
                    <div class="prowork-stack">
                      {build.stack.map(t => <span class="build-tech">{t}</span>)}
                    </div>
                  )}
                </a>
              ))}
            </div>
          )}

          {otherPast.length > 0 && (
            <div class="past-list">
              <p class="past-label">Past work</p>
              {otherPast.map((build) => (
                <a href={build.url} target="_blank" rel="noopener noreferrer" class="past-item">
                  <div class="past-item-left">
                    <span class="past-title">{build.title}</span>
                    <span class="past-desc">{build.description}</span>
                  </div>
                  <div class="past-item-right">
                    {build.stack && build.stack.map(t => <span class="build-tech">{t}</span>)}
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {/* ── Contact ── */}
  <section class="page-section contact-section" id="contact">
    <div class="section-wrap">
      <div class="section-num" aria-hidden="true">05</div>
      <div class="contact-body">
        <h2 class="section-heading">Open to<br />work.</h2>
        <p class="contact-text">
          I work autonomously and take ownership end to end — remote-first, async-friendly, and I ship on time. Reach me on Telegram.
        </p>
        <div class="contact-links">
          {profile.social.telegram && (
            <a href={profile.social.telegram} target="_blank" rel="noopener noreferrer" class="contact-link">
              <Icon name="telegram" size={14} />
              @industrialprofi
            </a>
          )}
          {profile.social.github && (
            <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="contact-link">
              <Icon name="github" size={14} />
              yurik2718
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

</Base>

<script>
  import { gsap } from 'gsap'

  const REDUCED_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const SMALL_SCREEN   = window.matchMedia('(max-width: 767px)').matches

  async function initThree() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null
    if (!canvas) return

    // Skip the WebGL hero on reduced-motion preference or small screens —
    // this avoids downloading ~0.5 MB of Three.js and saves battery on mobile.
    if (REDUCED_MOTION || SMALL_SCREEN) return

    const THREE = await import('three')

    const section = canvas.closest('section') as HTMLElement

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true })
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2))

    const scene = new THREE.Scene()
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100)
    camera.position.z = 4.5

    const geo = new THREE.IcosahedronGeometry(1.8, 1)
    const mat = new THREE.MeshBasicMaterial({
      color: 0xeeebe6,
      wireframe: true,
      transparent: true,
      opacity: 0.1,
    })
    const mesh = new THREE.Mesh(geo, mat)
    scene.add(mesh)

    let mouseX = 0
    let mouseY = 0

    const onMouseMove = (e: MouseEvent) => {
      mouseX = (e.clientX / window.innerWidth - 0.5) * 2
      mouseY = -(e.clientY / window.innerHeight - 0.5) * 2
    }

    const onResize = () => {
      const w = section.offsetWidth
      const h = section.offsetHeight
      renderer.setSize(w, h, false)
      camera.aspect = w / h
      camera.updateProjectionMatrix()
    }

    window.addEventListener('mousemove', onMouseMove)
    window.addEventListener('resize', onResize)
    onResize()

    let frameId = 0
    let angle = 0

    const tick = () => {
      frameId = requestAnimationFrame(tick)
      angle += 0.004
      mesh.rotation.x = angle * 0.45 + mouseY * 0.12
      mesh.rotation.y = angle + mouseX * 0.12
      renderer.render(scene, camera)
    }
    tick()

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(frameId)
      window.removeEventListener('mousemove', onMouseMove)
      window.removeEventListener('resize', onResize)
      renderer.dispose()
      geo.dispose()
      mat.dispose()
    }, { once: true })
  }

  function initAnim() {
    const avatar    = document.getElementById('hero-avatar')
    const available = document.getElementById('hero-available')
    const name      = document.getElementById('hero-name')
    const rule      = document.getElementById('hero-rule')
    const roles     = document.getElementById('hero-roles')
    const actions   = document.getElementById('hero-actions')
    const cue       = document.getElementById('scroll-cue')

    if (!name) return

    const els = [avatar, available, name, rule, roles, actions, cue].filter(Boolean)

    // Respect reduced-motion: reveal everything at once, no entrance animation.
    if (REDUCED_MOTION) {
      gsap.set(els, { opacity: 1, y: 0 })
      return
    }

    gsap.set(els, { opacity: 0, y: 18 })

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 0.1 })
    tl.to(avatar,    { opacity: 1, y: 0, duration: 0.5, scale: 1, clearProps: 'scale' })
    tl.to(available, { opacity: 1, y: 0, duration: 0.45 }, '-=0.25')
    tl.to(name,      { opacity: 1, y: 0, duration: 0.75 }, '-=0.3')
    tl.to(rule,      { opacity: 1, y: 0, duration: 0.4 }, '-=0.3')
    tl.to(roles,     { opacity: 1, y: 0, duration: 0.5 }, '-=0.25')
    tl.to(actions,   { opacity: 1, y: 0, duration: 0.4 }, '-=0.2')
    tl.to(cue,       { opacity: 1, y: 0, duration: 0.4 }, '-=0.1')
  }

  initThree()
  initAnim()
  document.addEventListener('astro:after-swap', () => {
    initThree()
    initAnim()
  })
</script>

<style>
  /* ══ Hero ══ */
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 5rem 1.5rem 6rem;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 820px;
    width: 100%;
  }

  /* Avatar */
  .hero-avatar {
    width: 88px;
    height: 88px;
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 1.75rem;
    border: 1px solid rgba(238, 235, 230, 0.12);
    box-shadow: 0 0 0 4px rgba(238, 235, 230, 0.04);
  }

  @media (min-width: 768px) {
    .hero-avatar {
      width: 104px;
      height: 104px;
    }
  }

  .hero-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(15%);
  }

  /* Available badge */
  .hero-available {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(238, 235, 230, 0.38);
    margin-bottom: 2rem;
  }

  .avail-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
    animation: avail-pulse 2.2s ease infinite;
  }

  @keyframes avail-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  /* Name */
  .hero-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(3.5rem, 10vw, 9rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  /* Divider */
  .hero-rule {
    width: 100%;
    max-width: 380px;
    height: 1px;
    background: rgba(238, 235, 230, 0.1);
    margin-bottom: 1.75rem;
  }

  /* Roles row */
  .hero-roles {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2.75rem;
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: rgba(238, 235, 230, 0.52);
  }

  .hero-role--dim { color: rgba(238, 235, 230, 0.28); }

  .hero-sep {
    color: rgba(238, 235, 230, 0.15);
    font-size: 0.55rem;
  }

  /* Buttons */
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.25rem;
    border: 1px solid rgba(238, 235, 230, 0.13);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: rgba(238, 235, 230, 0.45);
    text-decoration: none;
    border-radius: 2px;
    transition: border-color 0.22s, color 0.22s, background 0.22s;
  }

  .hero-btn:hover {
    border-color: rgba(238, 235, 230, 0.35);
    color: var(--color-primary);
  }

  .hero-btn--primary {
    border-color: rgba(238, 235, 230, 0.28);
    color: var(--color-primary);
    background: rgba(238, 235, 230, 0.04);
  }

  .hero-btn--primary:hover {
    background: rgba(238, 235, 230, 0.08);
    border-color: rgba(238, 235, 230, 0.45);
  }

  /* Scroll cue */
  .scroll-cue {
    position: absolute;
    bottom: 2.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
  }

  .scroll-cue-label {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(238, 235, 230, 0.18);
  }

  .scroll-cue-line {
    width: 1px;
    height: 38px;
    background: linear-gradient(to bottom, rgba(238, 235, 230, 0.25), transparent);
    animation: cue-slide 2.5s ease-in-out infinite;
  }

  @keyframes cue-slide {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 0; }
    30%  { opacity: 1; }
    100% { transform: scaleY(1); transform-origin: top; opacity: 0; }
  }

  /* ══ Shared section layout ══ */
  .page-section {
    padding: 8rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .section-wrap {
    position: relative;
    max-width: var(--container-grid);
    margin: 0 auto;
  }

  .section-num {
    position: absolute;
    top: -2.5rem;
    left: -0.25rem;
    font-family: var(--font-mono);
    font-size: clamp(5rem, 14vw, 11rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.028);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.06em;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-primary);
    line-height: 1.05;
    margin-bottom: 3rem;
    position: relative;
  }

  /* ══ About ══ */
  .about-body {
    max-width: 580px;
  }

  .about-text {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--color-secondary);
    margin-bottom: 1.25rem;
  }

  .about-tags {
    display: flex;
    gap: 2.5rem;
    margin-top: 3.5rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .about-tag { display: flex; flex-direction: column; gap: 0.3rem; }

  .about-tag-key {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: rgba(238, 235, 230, 0.22);
  }

  .about-tag-val {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ══ Skills ══ */
  .skills-body { position: relative; }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem 5rem;
    }
  }

  .skill-col-title {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(238, 235, 230, 0.28);
    margin-bottom: 2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .skill-group { margin-bottom: 1.75rem; }

  .skill-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(238, 235, 230, 0.2);
    margin-bottom: 0.5rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(238, 235, 230, 0.48);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.22rem 0.65rem;
    border-radius: 2px;
    letter-spacing: 0.02em;
    transition: color 0.2s, border-color 0.2s;
  }

  .skill-tag:hover {
    color: var(--color-primary);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .skill-tag--exploring {
    color: rgba(238, 235, 230, 0.75);
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.04);
  }

  /* ══ Builds ══ */
  .builds-body { position: relative; }

  .build-hero {
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.02);
    padding: 2.5rem;
    margin-bottom: 2.5rem;
    position: relative;
  }

  .build-hero::before {
