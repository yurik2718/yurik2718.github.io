---
import Base from '../layouts/Base.astro'
import BuildCard from '../components/BuildCard.astro'
import Icon from '../components/Icon.astro'
import { profile } from '../data/profile'
import { getCollection } from 'astro:content'
import { builds, kindLabel } from '../data/builds'

const allBooks = await getCollection('books')
const currentlyReading = allBooks.find((b) => b.data.status === 'reading')

const nowEntries = await getCollection('now')
const nowEntry = nowEntries[0]
const nowDate = nowEntry?.data.updatedAt
const daysSinceNow = nowDate ? Math.floor((Date.now() - nowDate.getTime()) / 86400000) : null
const nowLabel = daysSinceNow === 0 ? 'today' : daysSinceNow === 1 ? 'yesterday' : daysSinceNow != null ? `${daysSinceNow}d ago` : ''
const nowFresh = daysSinceNow != null && daysSinceNow < 14

const sorted = [...builds].sort((a, b) => a.position - b.position)
const heroProject = sorted.find(b => b.status === 'active')
const activeProjects = sorted.filter(b => b.status === 'active' && b !== heroProject)
const upcoming = sorted.filter(b => b.status === 'soon')

const heroSince = heroProject?.startedOn
  ? new Date(heroProject.startedOn).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
  : null
---

<Base title={profile.name} description={profile.bio}>

  {/* ── Hero ── */}
  <section class="home-layout">
    <div class="home-center">

      <div class="hero-avatar" id="hero-avatar">
        <img
          src={profile.avatar}
          alt={profile.name}
          class="h-full w-full object-cover"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="hidden h-full w-full items-center justify-center bg-surface text-[#3f3f46] text-3xl font-[family-name:var(--font-heading)]">
          {profile.name.split(' ').map((n) => n[0]).join('')}
        </div>
      </div>

      <div class="name-wrapper">
        <h1 class="home-name" id="hero-name">{profile.name}</h1>
        <svg class="name-underline" id="name-underline" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true">
          <path d="M 2 9 C 18 3, 62 12, 118 7 C 172 2, 228 11, 274 8 L 298 9" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <p class="home-bio" id="hero-bio">{profile.bio}</p>

      <div class="home-divider" id="hero-divider" />

      <div class="hero-links" id="hero-links">
        {currentlyReading && (
          <a href="/books" class="hero-link-item" data-nav>
            <span class="nav-label">Reading</span>
            <span class="nav-sep">·</span>
            <span class="nav-reading">{currentlyReading.data.title}</span>
          </a>
        )}

        {currentlyReading && <span class="links-sep">·</span>}

        <a href="/now" class="hero-link-item" data-nav>
          <span class="nav-label">Now</span>
          {nowFresh && (
            <span class="now-indicator">
              <span class="now-ping" />
              <span class="now-dot" />
            </span>
          )}
          <span class="nav-value now-meta">
            {nowFresh ? `Updated ${nowLabel}` : 'Status'}
          </span>
        </a>
      </div>

      <div class="home-social" id="hero-social">
        {profile.social.github && (
          <a href={profile.social.github} target="_blank" rel="noopener noreferrer" class="social-link">
            <Icon name="github" size={16} />
          </a>
        )}
        {profile.social.telegram && (
          <a href={profile.social.telegram} target="_blank" rel="noopener noreferrer" class="social-link">
            <Icon name="telegram" size={16} />
          </a>
        )}
      </div>

    </div>

    <div class="scroll-hint" id="scroll-hint">
      <div class="scroll-line" />
    </div>
  </section>

  {/* ── Builds ── */}
  <section class="builds-section">

    <div class="mx-auto max-w-[var(--container-grid)] px-5 pt-16 pb-10">
      <div class="flex items-center gap-4 build-fade" style="animation-delay: 0ms">
        <span class="section-label">Builds</span>
        <div class="flex-1 h-px bg-subtle" />
      </div>
    </div>

    {heroProject && (
      <div class="hero-strip build-fade" style="animation-delay: 60ms">
        <div class="mx-auto max-w-[var(--container-grid)] px-5">
          <div class="hero-meta">
            <span class="hero-kind">{kindLabel[heroProject.kind]}</span>
            <span class="hero-dot">·</span>
            <span class="hero-status-pill">{heroProject.status}</span>
            {heroSince && <span class="hero-since">Since {heroSince}</span>}
          </div>
          <a href={heroProject.url} target="_blank" rel="noopener noreferrer" class="hero-project-link group">
            <h2 class="hero-title">{heroProject.title}</h2>
            <span class="hero-arrow"><Icon name="arrow-up-right" size={30} /></span>
          </a>
          <p class="hero-desc">{heroProject.description}</p>
          {heroProject.stack && heroProject.stack.length > 0 && (
            <div class="hero-stack">
              {heroProject.stack.map(tech => (
                <span class="hero-tech">{tech}</span>
              ))}
            </div>
          )}
        </div>
        <div class="hero-accent-bar" />
      </div>
    )}

    {activeProjects.length > 0 && (
      <div class="mx-auto max-w-[var(--container-grid)] px-5 pt-10">
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          {activeProjects.map((build, i) => (
            <div class="build-fade" style={`animation-delay: ${120 + i * 80}ms`}>
              <BuildCard build={build} />
            </div>
          ))}
        </div>
      </div>
    )}

    {upcoming.length > 0 && (
      <div class="mx-auto max-w-[var(--container-grid)] px-5 pt-10 build-fade" style={`animation-delay: ${120 + activeProjects.length * 80 + 80}ms`}>
        <div class="flex items-center gap-4 mb-6">
          <span class="font-[family-name:var(--font-mono)] text-xs text-[#8aa1a3] tracking-wider uppercase opacity-75">On the horizon</span>
          <div class="flex-1 h-px bg-subtle" />
        </div>
        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
          {upcoming.map((build) => (
            <div class="group flex items-start gap-4 rounded-sm border border-white/[0.03] bg-card/50 p-5 transition-colors hover:bg-surface/50">
              <div class="flex-1 min-w-0">
                <h3 class="font-[family-name:var(--font-heading)] text-lg text-[#52525b] group-hover:text-secondary transition-colors leading-snug mb-1.5">
                  {build.title}
                </h3>
                <p class="text-sm text-[#3f3f46] leading-relaxed mb-3">{build.description}</p>
                {build.stack && build.stack.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {build.stack.map((tech) => (
                      <span class="font-[family-name:var(--font-mono)] text-[10px] text-[#3f3f46] bg-subtle px-1.5 py-0.5 rounded">
                        {tech}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="pb-24" />

  </section>

</Base>

<script>
  import { gsap } from 'gsap'

  function initHomeAnimation() {
    const nameEl = document.getElementById('hero-name')
    const avatarEl = document.getElementById('hero-avatar')
    const bioEl = document.getElementById('hero-bio')
    const dividerEl = document.getElementById('hero-divider')
    const linksEl = document.getElementById('hero-links')
    const socialEl = document.getElementById('hero-social')

    if (!nameEl) return

    const underlinePath = document.querySelector<SVGPathElement>('#name-underline path')
    const navItems = linksEl ? linksEl.querySelectorAll('[data-nav]') : []

    if (avatarEl) gsap.killTweensOf(avatarEl)

    gsap.set(avatarEl, { opacity: 0, scale: 0.85 })
    gsap.set(nameEl, { opacity: 0, y: 14 })
    gsap.set(bioEl, { opacity: 0, y: 12 })
    gsap.set(dividerEl, { opacity: 0 })
    gsap.set(navItems, { opacity: 0, y: 8 })
    gsap.set(socialEl, { opacity: 0 })
    if (underlinePath) {
      const pl = underlinePath.getTotalLength()
      gsap.set(underlinePath, { strokeDasharray: pl, strokeDashoffset: pl })
    }

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 0.15 })

    tl.to(avatarEl, { opacity: 1, scale: 1, duration: 0.5 })
    tl.to(nameEl, { opacity: 1, y: 0, duration: 0.7 }, '-=0.3')

    if (underlinePath) {
      tl.to(underlinePath, { strokeDashoffset: 0, duration: 0.9, ease: 'power2.in' }, '-=0.4')
    }

    tl.to(bioEl, { opacity: 1, y: 0, duration: 0.4 }, '-=0.25')
    tl.to(dividerEl, { opacity: 1, duration: 0.4, ease: 'power2.out' }, '-=0.15')
    tl.to(navItems, { opacity: 1, y: 0, duration: 0.4, stagger: 0.08 }, '-=0.2')
    tl.to(socialEl, { opacity: 1, duration: 0.3 }, '-=0.3')

    tl.call(() => {
      if (avatarEl) {
        gsap.to(avatarEl, {
          scale: 1.012,
          duration: 3,
          ease: 'sine.inOut',
          yoyo: true,
          repeat: -1,
        })
      }
    })

    if (avatarEl instanceof HTMLElement) {
      avatarEl.addEventListener('mouseenter', () => {
        gsap.to(avatarEl, {
          boxShadow: '0 0 0 1px rgba(196, 92, 40, 0.18), 0 0 36px rgba(196, 92, 40, 0.22)',
          duration: 0.5,
          ease: 'power2.out',
        })
      })
      avatarEl.addEventListener('mouseleave', () => {
        gsap.to(avatarEl, {
          boxShadow: '0 0 0 1px rgba(17, 17, 17, 0.10), 0 0 24px rgba(225, 87, 53, 0.08)',
          duration: 0.7,
          ease: 'power2.out',
        })
      })
    }

    navItems.forEach((item) => {
      if (!(item instanceof HTMLElement)) return
      item.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = item.getBoundingClientRect()
        const x = e.clientX - rect.left - rect.width / 2
        const y = e.clientY - rect.top - rect.height / 2
        gsap.to(item, { x: x * 0.08, y: y * 0.08, duration: 0.3, ease: 'power2.out' })
      })
      item.addEventListener('mouseleave', () => {
        gsap.to(item, { x: 0, y: 0, duration: 0.4, ease: 'power2.out' })
      })
    })
  }

  initHomeAnimation()
  document.addEventListener('astro:after-swap', initHomeAnimation)
</script>

<style>
  /* ═══ Hero layout ═══ */
  .home-layout {
    height: 100dvh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    position: relative;
  }

  .home-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 540px;
    width: 100%;
  }

  /* ═══ Avatar ═══ */
  .hero-avatar {
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 1.75rem;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(17, 17, 17, 0.10),
      0 0 24px rgba(225, 87, 53, 0.08);
  }

  @media (min-width: 768px) {
    .hero-avatar {
      width: 7rem;
      height: 7rem;
      margin-bottom: 2rem;
    }
  }

  /* ═══ Name ═══ */
  .name-wrapper {
    position: relative;
    width: 100%;
    margin-bottom: 1rem;
    padding-bottom: 14px;
  }

  .name-underline {
    position: absolute;
    bottom: 0;
    left: 3%;
    width: 94%;
    height: 12px;
    overflow: visible;
  }

  .name-underline path {
    stroke: var(--color-accent);
    stroke-width: 2px;
    opacity: 0.5;
  }

  .home-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--color-primary);
    margin-bottom: 0;
  }

  /* ═══ Bio ═══ */
  .home-bio {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #645849;
    max-width: 28rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .home-bio { font-size: 1rem; }
  }

  /* ═══ Divider ═══ */
  .home-divider {
    width: 100%;
    max-width: 320px;
    height: auto;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-divider::after {
    content: '· · ·';
    display: block;
    text-align: center;
    color: #aca49a;
    letter-spacing: 0.35em;
    font-size: 0.9rem;
    font-family: var(--font-ui);
    font-weight: 400;
  }

  /* ═══ Links row ═══ */
  .hero-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-link-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    border-radius: 2px;
    text-decoration: none;
    position: relative;
  }

  .hero-link-item::after {
    content: '';
    position: absolute;
    bottom: 3px;
    left: 0.75rem;
    right: 0.75rem;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s cubic-bezier(0.25, 0, 0, 1);
    opacity: 0.4;
  }

  .hero-link-item:hover::after { transform: scaleX(1); }
  .hero-link-item:hover .nav-label { color: var(--color-accent); transition: color 0.2s; }

  .links-sep {
    color: #bfb0a0;
    font-size: 11px;
    user-select: none;
  }

  .nav-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #857165;
    transition: color 0.2s;
  }

  .nav-sep { color: #bfb0a0; font-size: 11px; }

  .nav-value {
    font-family: var(--font-ui);
    font-size: 13px;
    color: #645849;
  }

  .nav-reading {
    font-family: var(--font-heading);
    font-size: 13px;
    color: var(--color-primary);
    font-style: italic;
  }

  /* ═══ Now indicator ═══ */
  .now-indicator {
    position: relative;
    display: flex;
    width: 0.375rem;
    height: 0.375rem;
  }

  .now-ping {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background-color: #34d399;
    opacity: 0.5;
    animation: now-ping 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .now-dot {
    position: relative;
    display: inline-flex;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 9999px;
    background-color: #34d399;
  }

  @keyframes now-ping {
    75%, 100% { transform: scale(2.5); opacity: 0; }
  }

  .now-meta { font-size: 11px; color: #857165; }

  /* ═══ Social ═══ */
  .home-social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .social-link {
    color: #857165;
    transition: color 0.2s;
  }

  .social-link:hover { color: var(--color-primary); }

  /* ═══ Scroll hint ═══ */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: hint-fade 0.5s ease 2s both;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    animation: scroll-slide 2.2s ease-in-out 2s infinite;
  }

  @keyframes hint-fade {
    from { opacity: 0; }
    to   { opacity: 0.45; }
  }

  @keyframes scroll-slide {
    0%   { transform: translateY(-10px); opacity: 0; }
    40%  { opacity: 1; }
    100% { transform: translateY(10px);  opacity: 0; }
  }

  /* ═══ Builds section ═══ */
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #857165;
    opacity: 0.75;
    white-space: nowrap;
  }

  @keyframes build-fade-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .build-fade {
    animation: build-fade-in 0.6s ease both;
  }

  /* ── Hero project strip ── */
  .hero-strip {
    background: #111111;
    padding: 3.5rem 0 4.5rem;
    position: relative;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .hero-kind {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8aa1a3;
    opacity: 0.75;
  }

  .hero-dot { color: rgba(245, 239, 230, 0.12); }

  .hero-status-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: rgba(225, 87, 53, 0.12);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .hero-since {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(245, 239, 230, 0.18);
  }

  .hero-project-link {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.75rem;
    text-decoration: none;
    margin-bottom: 1.75rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 7vw, 6.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    color: #f5efe6;
    transition: color 0.25s;
  }

  .hero-project-link:hover .hero-title { color: var(--color-accent); }

  .hero-arrow {
    color: rgba(245, 239, 230, 0.18);
    margin-top: 0.6rem;
    flex-shrink: 0;
    transition: color 0.25s, transform 0.25s;
  }

  .hero-project-link:hover .hero-arrow {
    color: var(--color-accent);
    transform: translate(4px, -4px);
  }

  .hero-desc {
    color: rgba(245, 239, 230, 0.4);
    font-size: 1rem;
    max-width: 540px;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-tech {
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(245, 239, 230, 0.28);
    background: rgba(245, 239, 230, 0.05);
    border: 1px solid rgba(245, 239, 230, 0.07);
    padding: 3px 10px;
    border-radius: 2px;
    letter-spacing: 0.02em;
  }

  .hero-accent-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-terra);
  }

  /* ═══ Mobile ═══ */
  @media (max-width: 767px) {
    .home-layout {
      height: auto;
      min-height: 100dvh;
      padding: 3rem 1.5rem 5rem;
    }
  }
</style>
