---
import Base from '../layouts/Base.astro'
import Icon from '../components/Icon.astro'
---

<Base
  title="Page not found — Andrey Yurik"
  description="Page not found."
>
  <section class="flex min-h-[70vh] flex-col items-center justify-center px-5 text-center">
    <p class="text-[8rem] md:text-[12rem] leading-none font-[family-name:var(--font-heading)] text-primary/5 select-none">
      404
    </p>
    <h1 class="text-2xl md:text-3xl -mt-8 mb-3">
      The trail ends here
    </h1>
    <p class="text-sm text-secondary mb-8">
      This page doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full border border-subtle bg-card px-5 py-2.5 text-sm text-accent hover:bg-surface transition-colors"
    >
      <Icon name="arrow-left" size={16} />
      <span>Back to base</span>
    </a>
  </section>
</Base>
