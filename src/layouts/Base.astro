---
import { Font } from 'astro:assets'
import { ClientRouter } from 'astro:transitions'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Effects from '../components/Effects.astro'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  image?: string
  canonicalUrl?: string
  type?: 'website' | 'article'
  publishedAt?: string
}

const {
  title,
  description,
  image,
  canonicalUrl,
  type = 'website',
  publishedAt,
} = Astro.props

const defaultOgImage = new URL('/og-default.png', Astro.site).href
const ogImage = image || defaultOgImage

const structuredData = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'Article' : 'WebSite',
  name: title,
  description,
  url: Astro.url.href,
  ...(type === 'article' && publishedAt ? { datePublished: publishedAt } : {}),
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl || Astro.url.href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#0a0a0a" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url.href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {publishedAt && <meta property="article:published_time" content={publishedAt} />}

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <Font cssVariable="--font-heading" />
    <Font cssVariable="--font-ui" />
    <Font cssVariable="--font-body" />
    <Font cssVariable="--font-mono" />

    <slot name="head" />

    <ClientRouter />
  </head>
  <body class="flex min-h-dvh flex-col bg-base text-primary font-[family-name:var(--font-ui)]">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <Effects />

    <script>
      import Lenis from 'lenis'

      function initLenis() {
        const lenis = new Lenis()
        function raf(time: number) {
          lenis.raf(time)
          requestAnimationFrame(raf)
        }
        requestAnimationFrame(raf)
      }

      initLenis()

      document.addEventListener('astro:after-swap', initLenis)
    </script>
  </body>
</html>
